{
  "name": "@flowscripter/dynamic-cli-framework",
  "version": "1.6.1",
  "description": "A framework for developing CLI applications which supports dynamic discovery and installation of new commands",
  "keywords": [
    "bun",
    "cli",
    "dynamic",
    "executable",
    "framework",
    "import",
    "plugin"
  ],
  "homepage": "https://github.com/flowscripter/dynamic-cli-framework#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flowscripter/dynamic-cli-framework.git"
  },
  "files": [
    "dist",
    "src",
    "index.ts",
    "cli-plugin.ts",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "bun": "./cli-plugin.ts",
      "types": "./dist/cli-plugin.d.ts",
      "default": "./dist/cli-plugin.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build index.ts cli-plugin.ts --outdir dist --target bun && tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@flowscripter/dynamic-plugin-framework": "1.9.0",
    "emphasize": "^7.0.0",
    "fastest-levenshtein": "^1.0.16",
    "figlet": "^1.11.0",
    "highlight.js": "^11.11.1",
    "prettier": "^3.9.4",
    "supports-color": "^10.2.2",
    "supports-terminal-graphics": "^0.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "typedocOptions": {
    "readme": "none",
    "exclude": [
      "tests/**"
    ]
  }
}
